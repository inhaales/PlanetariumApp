<Window x:Class="PlanetariumApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PlanetariumApp"
        mc:Ignorable="d"
        Title="Цифровий Планетарій" Height="900" Width="1600" Background="#0B0D17">

    <Window.Resources>
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="#111422"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid x:Name="Bg" SnapsToDevicePixels="true" Background="{TemplateBinding Background}">
                            <Track x:Name="PART_Track" IsDirectionReversed="true" IsEnabled="{TemplateBinding IsEnabled}">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#2E3553" CornerRadius="4"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter Property="Width" Value="10"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#111422" BorderBrush="#1E2337" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="ПЛАНЕТАРІЙ" 
                           Foreground="#4E9F3D" 
                           FontSize="22" 
                           FontWeight="Black" 
                           HorizontalAlignment="Center" 
                           Margin="0,30,0,30"
                           Grid.Row="0"/>

                <StackPanel Grid.Row="1" Margin="12,0,12,0">
                    <StackPanel.Resources>
                        <Style TargetType="Button">
                            <Setter Property="Height" Value="45"/>
                            <Setter Property="Margin" Value="0,4,0,4"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="#A0A5B5"/>
                            <Setter Property="FontSize" Value="14"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Left"/>
                            <Setter Property="Padding" Value="15,0,0,0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="BtnBorder" 
                                                Background="{TemplateBinding Background}" 
                                                CornerRadius="8" 
                                                BorderThickness="0">
                                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                                              VerticalAlignment="Center" 
                                                              Margin="{TemplateBinding Padding}"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="BtnBorder" Property="Background" Value="#1C2137"/>
                                                <Setter Property="Foreground" Value="#FFFFFF"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="BtnBorder" Property="Background" Value="#1E3A8A"/>
                                                <Setter Property="Foreground" Value="#61A3FF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </StackPanel.Resources>

                    <Button Content="Словник термінів" Click="Menu_Glossary_Click"/>
                    <Button Content="Космічні об'єкти" Click="Menu_CelestialBodies_Click"/>
                    <Button Content="Сузір'я неба" Click="Menu_Constellations_Click"/>
                    <Button Content="Космічні місії" Click="Menu_Missions_Click"/>
                    <Button Content="Астро-Вікторина" Click="Menu_Quiz_Click"/>
                    <Button Content="Космічна вага" Click="Menu_WeightCalculator_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Margin="25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock x:Name="PageTitle" 
                       Text="Головна сторінка" 
                       Foreground="White" 
                       FontSize="26" 
                       FontWeight="Bold" 
                       Grid.Row="0" 
                       Margin="0,0,0,15"
                       Visibility="Collapsed"/>

            <Grid Grid.Row="1">
                <TextBlock x:Name="StatusText" 
                           Text="Ласкаво просимо до Планетарію" 
                           Foreground="White" 
                           FontSize="24" 
                           HorizontalAlignment="Center" 
                           VerticalAlignment="Center"/>

                <ListView x:Name="DataDisplayList" 
                          Grid.Row="1" 
                          Background="Transparent" 
                          BorderThickness="0" 
                          Margin="0,20,0,0" 
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          PreviewMouseWheel="DataDisplayList_PreviewMouseWheel"
                          Visibility="Collapsed">

                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0,0,0,15"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListViewItem">
                                        <Border x:Name="ItemBorder" 
                                                Background="Transparent" 
                                                CornerRadius="12" 
                                                BorderThickness="0">
                                            <ContentPresenter />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ItemBorder" Property="Background" Value="#252B44"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="ItemBorder" Property="Background" Value="#1E3A8A"/>
                                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#61A3FF"/>
                                                <Setter TargetName="ItemBorder" Property="BorderThickness" Value="1"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListView.ItemContainerStyle>

                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#161A2B" 
                            BorderBrush="#2E3553" 
                            BorderThickness="1" 
                            CornerRadius="12" 
                            Padding="20">

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Image Grid.Column="0"
                                       Source="{Binding Image}" 
                                       Width="160" 
                                       Height="160" 
                                       Stretch="UniformToFill" 
                                       Margin="0,0,20,0"
                                       VerticalAlignment="Top">
                                        <Image.Clip>
                                            <RectangleGeometry Rect="0,0,160,160" RadiusX="10" RadiusY="10"/>
                                        </Image.Clip>
                                    </Image>

                                    <StackPanel Grid.Column="1" VerticalAlignment="Top">
                                        <TextBlock x:Name="TitleTxt" 
                               Text="{Binding Title}" 
                               FontSize="20" 
                               FontWeight="Bold" 
                               Foreground="#61A3FF" 
                               TextWrapping="Wrap"
                               Margin="0,0,0,8"/>

                                        <TextBlock x:Name="DetailsTxt" 
                               Text="{Binding Details}" 
                               FontSize="14" 
                               Foreground="#C2C7D6" 
                               TextWrapping="Wrap" 
                               LineHeight="20"
                               Margin="0,0,0,15"/>

                                        <ItemsControl ItemsSource="{Binding AdditionalImages}">
                                            <ItemsControl.Style>
                                                <Style TargetType="ItemsControl">
                                                    <Style.Triggers>
                                                        <Trigger Property="HasItems" Value="False">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </ItemsControl.Style>
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel Orientation="Horizontal" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="0,5,15,5" 
                                                        CornerRadius="8" 
                                                        Background="#0A0C16" 
                                                        Padding="2" 
                                                        MaxWidth="180" 
                                                        MaxHeight="120" 
                                                        VerticalAlignment="Center">

                                                        <Image Source="{Binding}" 
                                                           Stretch="Uniform" 
                                                           HorizontalAlignment="Center" 
                                                           VerticalAlignment="Center">
                                                            <Image.Clip>
                                                                <RectangleGeometry Rect="0,0,180,120" RadiusX="6" RadiusY="6"/>
                                                            </Image.Clip>
                                                        </Image>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                    </StackPanel>
                                </Grid>
                            </Border>

                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=ListViewItem}, Path=IsSelected}" Value="True">
                                    <Setter TargetName="TitleTxt" Property="Foreground" Value="#FFFFFF"/>
                                    <Setter TargetName="DetailsTxt" Property="Foreground" Value="#E2E8F0"/>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <StackPanel x:Name="WeightCalcPanel" Visibility="Collapsed" VerticalAlignment="Center" HorizontalAlignment="Center" Width="400">
                    <TextBlock Text="Дізнайтеся свою вагу на інших планетах" Foreground="White" FontSize="18" Margin="0,0,0,25" HorizontalAlignment="Center" TextAlignment="Center"/>
                    <TextBlock Text="Ваша вага на Землі (кг):" Foreground="#C2C7D6" FontSize="14" Margin="0,0,0,5"/>
                    <TextBox x:Name="EarthWeightInput" Height="35" Background="#161A2B" Foreground="White" BorderBrush="#2E3553" FontSize="16" VerticalContentAlignment="Center" Padding="8,0,0,0" Margin="0,0,0,15">
                        <TextBox.Resources>
                            <Style TargetType="TextBox">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="TextBox">
                                            <Border x:Name="BaseBorder" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="6">

                                                <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                                            </Border>

                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="BorderBrush" Value="#61A3FF"/>
                                                </Trigger>
                                                <Trigger Property="IsFocused" Value="True">
                                                    <Setter Property="BorderBrush" Value="#61A3FF"/>
                                                    <Setter Property="Background" Value="#1C2137"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>
                    <TextBlock Text="Оберіть космічний об'єкт:" Foreground="#C2C7D6" FontSize="14" Margin="0,0,0,5"/>

                    <ComboBox x:Name="PlanetComboBox" Height="35" FontSize="14" Margin="0,0,0,25" SelectedIndex="0">
                        <ComboBox.Resources>
                            <Style TargetType="ComboBoxItem">
                                <Setter Property="Padding" Value="10,6,10,6"/>
                                <Setter Property="Background" Value="#161A2B"/>
                                <Setter Property="Foreground" Value="#C2C7D6"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ComboBoxItem">
                                            <Border x:Name="ItemBorder" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="ItemBorder" Property="Background" Value="#252B44"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="ItemBorder" Property="Background" Value="#1E3A8A"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>

                            <Style TargetType="ComboBox">
                                <Setter Property="Background" Value="#161A2B"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="BorderBrush" Value="#2E3553"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="Padding" Value="10,0,0,0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ComboBox">
                                            <Grid x:Name="MainGrid" SnapsToDevicePixels="True">
                                                <Popup x:Name="PART_Popup" 
                                   AllowsTransparency="True" 
                                   Placement="Bottom" 
                                   IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}" 
                                   PopupAnimation="{DynamicResource {x:Static SystemParameters.ComboBoxPopupAnimationKey}}">
                                                    <Border x:Name="DropDownBorder" 
                                        Background="#161A2B" 
                                        BorderBrush="#2E3553" 
                                        BorderThickness="1" 
                                        CornerRadius="6" 
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}" 
                                        MinWidth="{Binding ActualWidth, ElementName=MainGrid}">
                                                        <ScrollViewer x:Name="DropDownScrollViewer" CanContentScroll="True">
                                                            <Grid RenderOptions.ClearTypeHint="Enabled">
                                                                <Canvas Height="0" Width="0" HorizontalAlignment="Left" VerticalAlignment="Top">
                                                                    <Rectangle x:Name="OpaqueRect" Height="{Binding ActualHeight, ElementName=DropDownBorder}" Width="{Binding ActualWidth, ElementName=DropDownBorder}" Fill="{Binding Background, ElementName=DropDownBorder}"/>
                                                                </Canvas>
                                                                <ItemsPresenter x:Name="ItemsPresenter" KeyboardNavigation.DirectionalNavigation="Contained" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                                            </Grid>
                                                        </ScrollViewer>
                                                    </Border>
                                                </Popup>

                                                <ToggleButton x:Name="ToggleButton" 
                                          Grid.ColumnSpan="2"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                                    <ToggleButton.Template>
                                                        <ControlTemplate TargetType="ToggleButton">
                                                            <Border x:Name="Border" 
                                                Background="{TemplateBinding Background}" 
                                                BorderBrush="{TemplateBinding BorderBrush}" 
                                                BorderThickness="{TemplateBinding BorderThickness}" 
                                                CornerRadius="6">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="Auto"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <Path x:Name="Arrow" 
                                                      Grid.Column="1"
                                                      Data="M 0 0 L 4 4 L 8 0" 
                                                      Stroke="#61A3FF" 
                                                      StrokeThickness="2" 
                                                      VerticalAlignment="Center" 
                                                      HorizontalAlignment="Center"
                                                      Margin="0,0,10,0"/>
                                                                </Grid>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="Border" Property="BorderBrush" Value="#61A3FF"/>
                                                                </Trigger>
                                                                <Trigger Property="IsChecked" Value="True">
                                                                    <Setter TargetName="Border" Property="BorderBrush" Value="#61A3FF"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </ToggleButton.Template>
                                                </ToggleButton>

                                                <ContentPresenter x:Name="ContentSite" 
                                              IsHitTestVisible="False" 
                                              Content="{TemplateBinding SelectionBoxItem}" 
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" 
                                              ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}" 
                                              VerticalAlignment="Center" 
                                              HorizontalAlignment="Left"
                                              Margin="{TemplateBinding Padding}"/>
                                            </Grid>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ComboBox.Resources>

                        <ComboBoxItem Content="Меркурій" Tag="0.38"/>
                        <ComboBoxItem Content="Венера" Tag="0.91"/>
                        <ComboBoxItem Content="Марс" Tag="0.38"/>
                        <ComboBoxItem Content="Юпітер" Tag="2.34"/>
                        <ComboBoxItem Content="Сатурн" Tag="1.06"/>
                        <ComboBoxItem Content="Уран" Tag="0.92"/>
                        <ComboBoxItem Content="Нептун" Tag="1.19"/>
                        <ComboBoxItem Content="Місяць" Tag="0.16"/>
                        <ComboBoxItem Content="Сонце" Tag="27.01"/>
                    </ComboBox>

                    <Button Content="Розрахувати" Height="40" Background="#4E9F3D" Foreground="White" FontWeight="Bold" BorderThickness="0" Click="CalculateWeight_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="5"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                    <TextBlock x:Name="WeightResultTextBlock" Text="" Foreground="#61A3FF" FontSize="22" FontWeight="Bold" Margin="0,30,0,0" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap"/>
                </StackPanel>

                <StackPanel x:Name="QuizPanel" 
                            Visibility="Collapsed" 
                            VerticalAlignment="Center" 
                            HorizontalAlignment="Stretch" 
                            Margin="50,0,50,0">
                    <TextBlock x:Name="QuestionTextBlock" 
                               Text="Тут буде запитання?" 
                               Foreground="White" 
                               FontSize="22" 
                               FontWeight="Bold" 
                               TextWrapping="Wrap" 
                               Margin="0,0,0,30" 
                               HorizontalAlignment="Center"
                               TextAlignment="Center"/>
                    <Button x:Name="BtnAnswerA" Height="45" Margin="0,6,0,6" Click="AnswerButton_Click" Tag="A" Background="#161A2B" BorderThickness="1" BorderBrush="#2E3553" Foreground="White" FontSize="15">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8" />
                            </Style>
                        </Button.Resources>
                    </Button>
                    <Button x:Name="BtnAnswerB" Height="45" Margin="0,6,0,6" Click="AnswerButton_Click" Tag="B" Background="#161A2B" BorderThickness="1" BorderBrush="#2E3553" Foreground="White" FontSize="15">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8" />
                            </Style>
                        </Button.Resources>
                    </Button>
                    <Button x:Name="BtnAnswerC" Height="45" Margin="0,6,0,6" Click="AnswerButton_Click" Tag="C" Background="#161A2B" BorderThickness="1" BorderBrush="#2E3553" Foreground="White" FontSize="15">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8" />
                            </Style>
                        </Button.Resources>
                    </Button>
                    <Button x:Name="BtnAnswerD" Height="45" Margin="0,6,0,6" Click="AnswerButton_Click" Tag="D" Background="#161A2B" BorderThickness="1" BorderBrush="#2E3553" Foreground="White" FontSize="15">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8" />
                            </Style>
                        </Button.Resources>
                    </Button>
                    <TextBlock x:Name="QuizScoreTextBlock" 
                               Text="Рахунок: 0" 
                               Foreground="#4E9F3D" 
                               FontSize="18" 
                               FontWeight="Bold" 
                               Margin="0,25,0,0" 
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>